{
  "version": "7.3",
  "screens": [
    {
      "id": "CONFIRM_ITEMS",
      "title": "Confirm Items",
      "data": {
        "items_source": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {"type": "string"},
              "title": {"type": "string"},
              "description": {"type": "string"},
              "image": {"type": "string"},
              "alt-text": {"type": "string"}
            },
            "required": ["id", "title"]
          },
          "__example__": [
            {
              "id": "0",
              "title": "Shirt",
              "description": "3 pieces",
              "image": "",
              "alt-text": "Shirt"
            },
            {
              "id": "1",
              "title": "Trousers",
              "description": "2 pieces",
              "image": "",
              "alt-text": "Trousers"
            }
          ]
        },
        "items_json": {"type": "string", "__example__": ""},
        "confirmed_items": {
          "type": "array",
          "items": {"type": "string"},
          "__example__": ["0", "1"]
        },

        "customer_name": {"type": "string", "__example__": ""},
        "customer_phone": {"type": "string", "__example__": ""},
        "pickup_date": {"type": "string", "__example__": ""},
        "total_amount": {"type": "number", "__example__": 0},
        "min_date": {"type": "string", "__example__": "2026-06-02"}
      },

      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "confirm_form",
            "init-values": {
              "confirmed_items": "${data.confirmed_items}"
            },
            "children": [
              {
                "type": "CheckboxGroup",
                "name": "confirmed_items",
                "label": "Review your entry",
                "required": true,
                "data-source": "${data.items_source}"
              },
              {
                "type": "TextCaption",
                "text": "PS: unchecking an item removes it from the entry"
              },
              {
                "type": "Footer",
                "label": "Continue",
                "on-click-action": {
                  "name": "navigate",
                  "next": {
                    "type": "screen",
                    "name": "ADDITIONAL_DETAILS"
                  },
                  "payload": {
                    "confirmed_items": "${form.confirmed_items}",
                    "items_json": "${data.items_json}",
                    "customer_name": "${data.customer_name}",
                    "customer_phone": "${data.customer_phone}",
                    "pickup_date": "${data.pickup_date}",
                    "total_amount": "${data.total_amount}",
                    "min_date": "${data.min_date}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "ADDITIONAL_DETAILS",
      "title": "Additional Details",
      "terminal": true,
      "data": {
        "confirmed_items": {
          "type": "array",
          "items": {"type": "string"},
          "__example__": ["0", "1"]
        },
        "items_json": {
          "type": "string",
          "__example__": "[{\"itemName\":\"Shirt\",\"quantity\":3}]"
        },
        "customer_name": {"type": "string", "__example__": ""},
        "customer_phone": {"type": "string", "__example__": ""},
        "pickup_date": {"type": "string", "__example__": ""},
        "total_amount": {"type": "number", "__example__": 0},
        "min_date": {"type": "string", "__example__": "2026-06-02"}
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Extra Information"
          },
          {
            "type": "Form",
            "name": "order_form",
            "init-values": {
              "customer_name": "${data.customer_name}",
              "customer_phone": "${data.customer_phone}"
            },
            "children": [
              {
                "type": "TextInput",
                "name": "customer_name",
                "label": "Customer Name",
                "input-type": "text",
                "required": false
              },
              {
                "type": "TextInput",
                "name": "customer_phone",
                "label": "Customer Phone",
                "input-type": "phone",
                "required": true,
                "helper-text": "customer's contact (e.g. 08102...)"
              },
              {
                "type": "CalendarPicker",
                "name": "pickup_date",
                "label": "Pickup Date",
                "mode": "single",
                "min-date": "${data.min_date}",
                "required": false
              },
              {
                "type": "TextInput",
                "name": "total_amount",
                "label": "Total Amount",
                "input-type": "number",
                "helper-text": "enter total amount (e.g. 12450)",
                "required": true
              },
              {
                "type": "Footer",
                "label": "Confirm Order",
                "on-click-action": {
                  "name": "complete",
                  "payload": {
                    "confirmed_items": "${data.confirmed_items}",
                    "customer_name": "${form.customer_name}",
                    "customer_phone": "${form.customer_phone}",
                    "pickup_date": "${form.pickup_date}",
                    "total_amount": "${form.total_amount}",
                    "items_json": "${data.items_json}"
                  }
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
